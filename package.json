{
  "name": "prisma-effect-schema",
  "version": "0.1.0",
  "description": "Prisma generator that creates Effect Schemas from your Prisma models",
  "keywords": [
    "prisma",
    "effect",
    "schema",
    "generator",
    "typescript",
    "validation"
  ],
  "license": "MIT",
  "author": "Frontcore",
  "repository": {
    "type": "git",
    "url": "https://github.com/frontcore/prisma-effect-schema.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./generator": {
      "types": "./dist/generator.d.ts",
      "import": "./dist/generator.js"
    }
  },
  "bin": {
    "prisma-effect-schema": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@prisma/generator-helper": "^6.5.0",
    "dedent": "^1.7.2"
  },
  "devDependencies": {
    "@types/dedent": "^0.7.2",
    "@types/node": "^22.13.10",
    "effect": "^3.14.8",
    "prisma": "^6.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "peerDependencies": {
    "effect": ">=3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
